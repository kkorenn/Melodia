generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "darwin-arm64", "linux-arm64-openssl-3.0.x"]
}

datasource db {
  provider = "sqlite"
  url      = "file:../data/melodia.sqlite"
}

model Song {
  id            Int            @id @default(autoincrement())
  path          String         @unique
  filename      String
  title         String?
  artist        String?
  album         String?
  albumArtist   String?        @map("album_artist")
  year          Int?
  genre         String?
  trackNumber   Int?           @map("track_number")
  duration      Float?
  bitrate       Int?
  coverArt      Bytes?         @map("cover_art")
  coverArtMime  String?        @map("cover_art_mime")
  fileSize      Int?           @map("file_size")
  lastModified  BigInt         @map("last_modified")
  dateAdded     BigInt?        @map("date_added")
  playCount     Int            @default(0) @map("play_count")
  lastPlayed    BigInt?        @map("last_played")
  playHistory   PlayHistory[]
  playlistSongs PlaylistSong[]
  lyricsCache   LyricsCache?

  @@index([artist], map: "idx_songs_artist")
  @@index([album], map: "idx_songs_album")
  @@index([genre], map: "idx_songs_genre")
  @@index([title], map: "idx_songs_title")
  @@index([playCount(sort: Desc)], map: "idx_songs_play_count")
  @@index([lastPlayed(sort: Desc)], map: "idx_songs_last_played")
  @@index([dateAdded(sort: Desc)], map: "idx_songs_date_added")
  @@map("songs")
}

model PlayHistory {
  id       Int    @id @default(autoincrement())
  songId   Int    @map("song_id")
  playedAt BigInt @map("played_at")
  song     Song   @relation(fields: [songId], references: [id], onDelete: Cascade)

  @@index([playedAt(sort: Desc)], map: "idx_play_history_played_at")
  @@index([songId], map: "idx_play_history_song_id")
  @@map("play_history")
}

model Setting {
  key       String @id
  value     String
  updatedAt BigInt @map("updated_at")

  @@map("settings")
}

model Playlist {
  id           Int            @id @default(autoincrement())
  name         String
  coverArt     Bytes?         @map("cover_art")
  coverArtMime String?        @map("cover_art_mime")
  createdAt    BigInt         @map("created_at")
  updatedAt    BigInt         @map("updated_at")
  songs        PlaylistSong[]

  @@index([name], map: "idx_playlists_name")
  @@map("playlists")
}

model PlaylistSong {
  id         Int      @id @default(autoincrement())
  playlistId Int      @map("playlist_id")
  songId     Int      @map("song_id")
  position   Int
  addedAt    BigInt   @map("added_at")
  playlist   Playlist @relation(fields: [playlistId], references: [id], onDelete: Cascade)
  song       Song     @relation(fields: [songId], references: [id], onDelete: Cascade)

  @@unique([playlistId, songId])
  @@index([playlistId, position], map: "idx_playlist_songs_playlist_position")
  @@index([songId], map: "idx_playlist_songs_song_id")
  @@map("playlist_songs")
}

model LyricsCache {
  songId       Int     @id @map("song_id")
  provider     String
  status       String
  lyrics       String?
  language     String?
  copyright    String?
  trackId      Int?    @map("track_id")
  fetchedAt    BigInt  @map("fetched_at")
  expiresAt    BigInt  @map("expires_at")
  errorMessage String? @map("error_message")
  song         Song    @relation(fields: [songId], references: [id], onDelete: Cascade)

  @@index([expiresAt], map: "idx_lyrics_cache_expires_at")
  @@map("lyrics_cache")
}
